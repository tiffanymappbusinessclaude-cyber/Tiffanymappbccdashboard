# BCC Master Template — Environment Variables
# Copy this file to .env and fill in your values
# In Vercel: add these under Settings → Environment Variables

# Your Supabase project URL (Settings → API → Project URL)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anon/public key (Settings → API → anon public)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Your agency row ID from Supabase (run: SELECT id FROM agency LIMIT 1)
# Leave blank until after running migration 004
VITE_AGENCY_ID=

# Mock-data fallback for empty tables.
# - true (default): when a table returns 0 rows, render hardcoded MOCK
#   data so the UI looks populated. Useful for sales demos and for new
#   client deployments before any real data has been uploaded.
# - false: when a table returns 0 rows, render the EmptyState component
#   with module-specific guidance ("Add your first task by telling
#   your Claude...", etc). RECOMMENDED for production deployments
#   so agents see honest schema state.
# ⚠ PRODUCTION FLIP: set VITE_USE_MOCK_DATA=false in Vercel env vars for real
#   client deployments. Leaving it true means empty tables show hardcoded MOCK
#   data instead of the honest EmptyState components. See CLAUDE.md Rule #10.
VITE_USE_MOCK_DATA=true

# Demo mode flag — set to 'true' ONLY for the demo deployment
# When true, renders the DemoBanner component (yellow strip across top).
# Defaults to false / unset for client deploys — banner does not render.
VITE_DEMO_MODE=false
